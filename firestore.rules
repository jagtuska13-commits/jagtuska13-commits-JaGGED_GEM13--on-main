rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safe Default Guard (Default-Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidAppSettings(data) {
      return data.keys().hasAll(['systemInstruction', 'userName']) 
        && data.keys().size() == 2 
        && data.systemInstruction is string 
        && data.systemInstruction.size() <= 4000
        && data.userName is string 
        && data.userName.size() <= 100;
    }

    function isValidMemoryBank(data) {
      return data.keys().hasAll(['summary', 'facts', 'lastInteraction'])
        && data.keys().size() == 3
        && data.summary is string
        && data.summary.size() <= 10000
        && data.facts is list
        && data.facts.size() <= 100
        && data.lastInteraction is number;
    }

    function isValidChatSession(data) {
      return data.keys().hasAll(['id', 'title', 'messages', 'lastModified', 'module'])
        && data.keys().size() == 5
        && data.id is string
        && data.id.size() <= 128
        && data.title is string
        && data.title.size() <= 200
        && data.messages is list
        && data.lastModified is number
        && data.module is string;
    }

    // Rule matches (Users namespace isolating all data)
    match /users/{userId} {
      allow get, create, update: if isOwner(userId);
      
      match /config/settings {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidAppSettings(incoming());
      }
      
      match /config/memory {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMemoryBank(incoming());
      }
      
      match /sessions/{sessionId} {
        allow get: if isOwner(userId) && isValidId(sessionId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(sessionId) && isValidChatSession(incoming());
        allow update: if isOwner(userId) && isValidId(sessionId) && isValidChatSession(incoming());
        allow delete: if isOwner(userId) && isValidId(sessionId);
      }
    }
  }
}
